{
  "name": "skyecho-atc-discord-bridge",
  "version": "1.3.0",
  "description": "SkyEcho ATC Discord Bridge with synthetic AI traffic for Xbox MSFS pilots.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "register": "node scripts/register-commands.js",
    "check": "node scripts/self-check.js",
    "piper": "node scripts/piper-http-server.js",
    "start:piper": "node scripts/piper-http-server.js",
    "render:start": "node scripts/render-start.js",
    "install:vosk": "python3 -m pip install vosk",
    "download:vosk-model": "bash scripts/download-vosk-model.sh"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.9",
    "prism-media": "^1.3.5",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0"
  }
}
